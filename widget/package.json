{
  "name": "boxer-widget",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "description": "Public browser widget SDK and service-hosted UI for Boxer.",
  "main": "dist/sdk/index.js",
  "types": "dist/sdk/index.d.ts",
  "files": [
    "dist/sdk",
    "dist/widget"
  ],
  "exports": {
    ".": {
      "types": "./dist/sdk/index.d.ts",
      "default": "./dist/sdk/index.js"
    }
  },
  "scripts": {
    "dev": "vite --host 0.0.0.0 --port 4173",
    "dev:admin": "vite --mode admin --host 0.0.0.0 --port 4174",
    "build": "tsc -p tsconfig.json --noEmit && pnpm run build:widget && pnpm run build:admin && tsc -p tsconfig.sdk.json",
    "build:widget": "vite build --mode widget",
    "build:admin": "vite build --mode admin",
    "lint": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.sdk.json --noEmit",
    "preview": "vite preview --host 0.0.0.0 --port 4173"
  },
  "devDependencies": {
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^5.0.4",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "typescript": "^5.9.2",
    "vite": "^7.1.5"
  }
}
